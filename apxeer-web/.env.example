# Copy this file to .env.local for local development.
# All VITE_* vars are embedded at build time — never put secrets here.

# API base URL. The web calls ${VITE_API_URL}/api/laps, /api/sessions, etc.
# Local dev (Go API):
VITE_API_URL=http://localhost:8080
# Stage/Prod: VITE_API_URL=https://your-railway-api-url.railway.app

# Clerk publishable key — from Clerk Dashboard → API Keys
# Use the Test key for local dev, Live key for production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
