# Copy this file to .env.local for local development.
# All VITE_* vars are embedded at build time — never put secrets here.

# API base URL. The web calls ${VITE_API_URL}/api/laps, /api/sessions, etc.
# Local dev (Supabase CLI stack):
VITE_API_URL=http://localhost:54321/functions/v1
# Stage:  VITE_API_URL=https://<stage-ref>.supabase.co/functions/v1
# Prod:   VITE_API_URL=https://<prod-ref>.supabase.co/functions/v1

# Supabase project — used for OAuth (Google, Discord, GitHub) and session management.
# Get both values from: Supabase Dashboard → Settings → API
# Local dev (from `supabase start` output):
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=<anon-key-from-supabase-start>
# Stage/Prod: replace with the real project URL and anon key
